# Copy to .env and adjust. .env is gitignored.

LOG_LEVEL=INFO

# Required for --with_openai (OpenAI API summarization).
OPENAI_API_KEY=<your-openai-api-key>

# Required for --diarize (pyannote speaker diarization).
# Token must have access to pyannote/speaker-diarization-3.1 on Hugging Face.
HUGGINGFACE_TOKEN=<your-huggingface-token>
